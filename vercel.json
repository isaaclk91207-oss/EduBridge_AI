{
  "version": 2,
  "builds": [
    {
      "src": "app/app.py",
      "use": "@vercel/python"
    }
  ],
  "env": {
    "DATABASE_URL": "@database-url",
    "SECRET_KEY": "@secret-key",
    "PYTHON_VERSION": "3.11"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/app/app.py"
    }
  ]
}
